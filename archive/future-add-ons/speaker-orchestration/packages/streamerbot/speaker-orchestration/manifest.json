  "author": "surakage",
  "description": "Creator-approved Speaker.bot speech and queue-control boundary for THSV StreamBridge.",
  "minimumStreamerBotVersion": "1.0.5-alpha.31",
  "action": {
    "name": "THSV StreamBridge - Speaker Orchestration",
    "group": "THSV StreamBridge",
    "id": "0f738349-303a-5c90-926f-1134a736d232",
    "sourceSubActionId": "aaea2d03-d4e1-5725-af39-80e75b16c499",
    "source": "src/ProcessSpeakerRequest.cs",
    "importFile": "THSV-StreamBridge-Speaker-Orchestration-1.0.1.sb"
  },
  "runtime": {
    "queue": "Default",
    "concurrent": true,
    "dependencies": ["Streamer.bot CPH API", "Streamer.bot Speaker.bot integration", "Speaker.bot UDP interface on localhost port 6669"]
  },
  "contract": {
    "version": "1.0.0",
    "operations": ["speak", "stop", "pause", "resume", "clear"],
    "maximumMessageCharacters": 500,
    "requiredInputArguments": ["speakerOperation", "speakerApproved"],
    "conditionalInputArguments": ["speakerRequestId", "speakerVoiceAlias", "speakerMessage", "speakerTextSource", "speakerSimulated", "speakerAllowSimulated", "speakerDryRun"],
    "outputArguments": ["speakerHandled", "speakerValid", "speakerValidationError", "speakerContractVersion", "speakerPackageVersion", "speakerRequestId", "speakerOperationResult", "speakerTransport", "speakerDispatched", "speakerDryRunResult", "speakerSimulatedResult", "speakerBadWordFilter", "speakerVoiceAliasResult", "speakerMessageResult", "speakerTextSourceResult", "speakerDispatchResult", "speakerGeneratedMetadataAvailable", "speakerDurationMs", "speakerAudioFile"],
    "safety": {
      "requiresCreatorApproval": true,
      "allowedTextSources": ["creator-template", "creator-approved"],
      "deniedTextSource": "raw-event",
      "badWordFilter": "always-on",
      "simulatedDefault": "deny",
      "directTriggers": false
    }
  }
}
