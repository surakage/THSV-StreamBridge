{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subathon Timer",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": { "type": "boolean", "title": "Enable Subathon Timer", "default": true },
    "enabledPlatforms": {
      "type": "array",
      "title": "Platforms that may affect the timer",
      "description": "One platform per line: twitch, youtube, kick, or tiktok.",
      "items": { "type": "string", "enum": ["twitch", "youtube", "kick", "tiktok"] },
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "default": ["twitch", "youtube", "kick", "tiktok"]
    },
    "autoStartWhenLive": { "type": "boolean", "title": "Start the timer automatically when a stream goes live", "default": true },
    "pauseWhenOffline": { "type": "boolean", "title": "Pause the timer when every selected platform is offline", "default": true },
    "resetToStartingMinutesOnStreamOnline": { "type": "boolean", "title": "Reset to the starting time when a new stream session begins", "default": true },
    "enableModeratorCommands": { "type": "boolean", "title": "Enable moderator and broadcaster timer control commands", "default": false },
    "startCommandName": { "type": "string", "title": "Start command", "pattern": "^[a-z][a-z0-9-]{0,63}$", "maxLength": 64, "default": "subathon-start" },
    "pauseCommandName": { "type": "string", "title": "Pause command", "pattern": "^[a-z][a-z0-9-]{0,63}$", "maxLength": 64, "default": "subathon-pause" },
    "resumeCommandName": { "type": "string", "title": "Resume command", "pattern": "^[a-z][a-z0-9-]{0,63}$", "maxLength": 64, "default": "subathon-resume" },
    "resetCommandName": { "type": "string", "title": "Reset command", "pattern": "^[a-z][a-z0-9-]{0,63}$", "maxLength": 64, "default": "subathon-reset" },
    "addTimeCommandName": { "type": "string", "title": "Add-time command", "pattern": "^[a-z][a-z0-9-]{0,63}$", "maxLength": 64, "default": "subathon-addtime" },
    "defaultManualAddSeconds": { "type": "integer", "title": "Default seconds added when the add-time command gets no argument", "minimum": 1, "maximum": 86400, "default": 300 },
    "startingMinutes": { "type": "integer", "title": "Starting timer length (minutes)", "minimum": 1, "maximum": 1440, "default": 60 },
    "maximumMinutes": { "type": "integer", "title": "Maximum timer cap (minutes)", "minimum": 1, "maximum": 4320, "default": 720 },
    "followSeconds": { "type": "integer", "title": "Seconds added per follow", "minimum": 0, "maximum": 3600, "default": 30 },
    "subscriptionSeconds": { "type": "integer", "title": "Seconds added per subscription", "minimum": 0, "maximum": 7200, "default": 300 },
    "membershipSeconds": { "type": "integer", "title": "Seconds added per YouTube membership", "minimum": 0, "maximum": 7200, "default": 300 },
    "giftSubscriptionSecondsEach": { "type": "integer", "title": "Seconds added per gifted subscription", "minimum": 0, "maximum": 7200, "default": 180 },
    "giftSecondsEach": { "type": "integer", "title": "Seconds added per engagement gift unit", "description": "Useful for TikTok and other gift-style alerts that expose a positive quantity.", "minimum": 0, "maximum": 3600, "default": 15 },
    "raidBaseSeconds": { "type": "integer", "title": "Base seconds added for a raid", "minimum": 0, "maximum": 7200, "default": 300 },
    "raidPerViewerSeconds": { "type": "integer", "title": "Extra seconds added per raid viewer", "minimum": 0, "maximum": 300, "default": 5 },
    "minimumRaidViewers": { "type": "integer", "title": "Minimum raid viewers before the raid bonus applies", "minimum": 1, "maximum": 1000000, "default": 1 },
    "likeThreshold": { "type": "integer", "title": "TikTok-like threshold", "description": "A bonus is added only when the total like counter crosses another full threshold. Example: 100 means 100, 200, 300, and so on.", "minimum": 1, "maximum": 1000000, "default": 100 },
    "likeThresholdAwardSeconds": { "type": "integer", "title": "Seconds added per completed like threshold", "minimum": 0, "maximum": 3600, "default": 45 },
    "showOverlay": { "type": "boolean", "title": "Publish timer state to the add-on overlay broker", "default": true },
    "overlayLabel": { "type": "string", "title": "Overlay label", "minLength": 1, "maxLength": 80, "default": "SUBATHON" },
    "overlayFontFamily": { "type": "string", "title": "Overlay font style", "enum": ["display", "broadcast", "mono"], "default": "display" },
    "overlayBackgroundMode": { "type": "string", "title": "Overlay background style", "enum": ["glass", "solid", "none"], "default": "glass" },
    "overlayBackgroundColor": { "type": "string", "title": "Overlay background color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#0b1017" },
    "overlayBackgroundOpacity": { "type": "number", "title": "Overlay background opacity", "minimum": 0, "maximum": 1, "default": 0.88 },
    "overlayAccentColor": { "type": "string", "title": "Accent color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#7ee0ff" },
    "overlayTextColor": { "type": "string", "title": "Primary text color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#eff7ff" },
    "overlayMutedColor": { "type": "string", "title": "Secondary text color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#dfefff" },
    "overlayWarningColor": { "type": "string", "title": "Warning color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#f0c15a" },
    "overlayCriticalColor": { "type": "string", "title": "Critical color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#ff6b7d" },
    "overlayLiveColor": { "type": "string", "title": "Live badge color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#61f2a4" },
    "overlayBorderColor": { "type": "string", "title": "Border color", "pattern": "^#[0-9a-fA-F]{6}$", "default": "#85cbff" },
    "overlayShowProgressBar": { "type": "boolean", "title": "Show the progress bar", "default": true },
    "warningMinutes": { "type": "integer", "title": "Warning threshold (minutes)", "minimum": 1, "maximum": 240, "default": 15 },
    "criticalMinutes": { "type": "integer", "title": "Critical threshold (minutes)", "minimum": 1, "maximum": 120, "default": 5 }
  }
}
