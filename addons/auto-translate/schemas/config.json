{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Auto Translate", "type": "object", "additionalProperties": false,
  "properties": {
    "enabled": { "type": "boolean", "title": "Enable automatic translation", "description": "Disabled by default. Review privacy, audience, and limits first.", "default": false },
    "enabledPlatforms": { "type": "array", "title": "Platforms allowed to use Auto Translate", "items": { "type": "string", "enum": ["twitch", "youtube", "kick", "tiktok"] }, "minItems": 1, "maxItems": 4, "uniqueItems": true, "default": ["twitch", "youtube", "kick", "tiktok"] },
    "audienceMode": { "type": "string", "title": "Who may be translated", "enum": ["allowlist-only", "all-viewers"], "default": "allowlist-only" },
    "allowedNames": { "type": "array", "title": "Allowed viewer names or platform user IDs", "description": "Used by the recommended allowlist-only mode. One exact name or ID per line.", "items": { "type": "string", "minLength": 1, "maxLength": 256 }, "maxItems": 500, "uniqueItems": true, "default": [] },
    "ignoredNames": { "type": "array", "title": "Never translate these names or IDs", "items": { "type": "string", "minLength": 1, "maxLength": 256 }, "maxItems": 500, "uniqueItems": true, "default": [] },
    "sourceLanguage": { "type": "string", "title": "Known source language", "description": "MyMemory does not provide automatic language detection here. Example: es.", "pattern": "^[a-z]{2,3}(?:-[a-z0-9]{2,8})?$", "maxLength": 20, "default": "es" },
    "targetLanguage": { "type": "string", "title": "Translate into", "description": "Must differ from the source language. Example: en.", "pattern": "^[a-z]{2,3}(?:-[a-z0-9]{2,8})?$", "maxLength": 20, "default": "en" },
    "commandPrefix": { "type": "string", "title": "Command prefix to ignore", "description": "Messages beginning with this character are never sent for automatic translation.", "minLength": 1, "maxLength": 1, "pattern": "^\\S$", "default": "!" },
    "responseTemplate": { "type": "string", "format": "multiline", "title": "Translated chat message", "description": "Tokens: {author}, {sourceLanguage}, {targetLanguage}, {translation}.", "minLength": 1, "maxLength": 1000, "default": "{author}: ({sourceLanguage} to {targetLanguage}) {translation}" },
    "showProviderErrors": { "type": "boolean", "title": "Post provider failures in chat", "description": "Off by default to avoid error-message spam.", "default": false },
    "errorMessage": { "type": "string", "format": "multiline", "title": "Provider failure message", "minLength": 1, "maxLength": 500, "default": "Automatic translation is temporarily unavailable." },
    "maximumInputCharacters": { "type": "integer", "title": "Maximum input characters", "minimum": 1, "maximum": 1000, "default": 500 },
    "timeoutSeconds": { "type": "integer", "title": "Provider timeout (seconds)", "minimum": 3, "maximum": 15, "default": 8 },
    "userCooldownSeconds": { "type": "integer", "title": "Per-viewer cooldown (seconds)", "minimum": 5, "maximum": 3600, "default": 60 },
    "globalCooldownSeconds": { "type": "integer", "title": "Global translation cooldown (seconds)", "minimum": 1, "maximum": 60, "default": 5 },
    "maximumPendingRequests": { "type": "integer", "title": "Maximum requests waiting", "minimum": 1, "maximum": 20, "default": 5 },
    "maximumTranslationsPerMinute": { "type": "integer", "title": "Maximum translations per minute", "minimum": 1, "maximum": 60, "default": 10 },
    "percentageWindowMessages": { "type": "integer", "title": "Chat messages in percentage window", "minimum": 10, "maximum": 500, "default": 100 },
    "percentageMinimumSample": { "type": "integer", "title": "Messages before percentage cap begins", "minimum": 1, "maximum": 100, "default": 10 },
    "maximumTranslatedPercentage": { "type": "integer", "title": "Maximum translated chat percentage", "minimum": 1, "maximum": 100, "default": 25 }
  }
}
