{
  "name": "@thsv/streambridge",
  "version": "2.0.0-preview.1",
  "private": true,
  "license": "MIT",
  "description": "A modular, local-first cross-platform livestream automation framework",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "addon:verify": "tsx tools/manage-addon.ts verify",
    "addon:install": "tsx tools/manage-addon.ts install",
    "addon:remove": "tsx tools/manage-addon.ts remove",
    "clean": "node tools/clean.mjs",
    "config:validate": "tsx tools/validate-config.ts",
    "dev": "tsx watch apps/bridge-service.ts",
    "lint": "eslint .",
    "package:streamerbot": "tsx tools/build-streamerbot-export.ts",
    "simulate": "tsx tools/simulate-event.ts",
    "simulate:burst": "tsx tools/simulate-burst.ts",
    "start": "node dist/apps/bridge-service.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
