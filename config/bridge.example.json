{
  "configVersion": "1.0.0",
  "service": {
    "name": "THSV StreamBridge",
    "host": "127.0.0.1",
    "port": 8787,
    "allowNetworkAccess": false,
    "shutdownTimeoutMs": 5000
  },
  "security": {
    "maxPayloadBytes": 262144,
    "preserveRawPayloads": false,
    "controlTokenEnv": "THSV_STREAMBRIDGE_CONTROL_TOKEN",
    "controlTokenFile": "data/runtime/control-token",
    "allowedOrigins": [],
    "maxRequestsPerMinute": 60,
    "maxConcurrentRequests": 4
  },
  "logging": {
    "level": "info",
    "directory": "data/logs",
    "maxFileBytes": 5242880,
    "backups": 3
  },
  "deduplication": {
    "ttlMs": 300000,
    "maxEntries": 10000,
    "persistAcrossRestarts": true,
    "stateFile": "data/state/deduplication.json"
  },
  "commands": {
    "enabled": true,
    "prefix": "!",
    "definitions": [
      { "name": "ping", "aliases": ["p"], "minimumRole": "viewer", "allowBots": false },
      { "name": "shoutout", "aliases": ["so"], "minimumRole": "moderator", "allowBots": false }
    ]
  },
  "timedActions": {
    "stateFile": "data/state/timed-actions.json",
    "definitions": []
  },
  "browserOverlay": {
    "enabled": true,
    "brandLabel": "THE HIDDEN SLOTH VILLAGE",
    "maxChatMessages": 8,
    "maxAlertQueue": 20,
    "alertDurationMs": 7000,
    "showBots": true,
    "showSimulated": true
  },
  "viewerIdentity": {
    "enabled": false,
    "stateFile": "data/state/viewer-progression.json",
    "includeSimulated": false,
    "processedEventTtlMs": 86400000,
    "maxProcessedEvents": 10000,
    "links": [],
    "progression": {
      "enabled": true,
      "points": {
        "chat.message": 1,
        "channel.follow": 10,
        "channel.subscription": 25,
        "channel.membership": 25,
        "channel.gift-subscription": 25,
        "engagement.gift": 5,
        "engagement.donation": 20,
        "engagement.cheer": 10,
        "engagement.super-chat": 20,
        "channel.raid": 25,
        "engagement.milestone": 5
      },
      "cooldownsMs": { "chat.message": 60000 },
      "levelThresholds": [0, 100, 250, 500, 1000]
    }
  },
  "streamerbot": {
    "enabled": true,
    "url": "ws://127.0.0.1:8080/",
    "allowRemote": false,
    "passwordEnv": "STREAMERBOT_PASSWORD",
    "actionAlias": "THSV StreamBridge - Receive Event",
    "acknowledgementTimeoutMs": 5000,
    "maxPendingRequests": 16,
    "deliveryQueueCapacity": 100,
    "deliveryConcurrency": 2,
    "deliveryFailureThreshold": 3,
    "testMode": false,
    "reconnect": {
      "enabled": true,
      "initialDelayMs": 250,
      "maxDelayMs": 10000,
      "maxAttempts": 8
    }
  },
  "platforms": {
    "twitch": { "enabled": false, "inputEnabled": true, "outputEnabled": false, "adapter": "twitch-placeholder", "capabilities": ["chatInput", "chatOutput", "follows", "subscriptions", "donations", "raids", "moderation", "channelUpdates"], "reconnect": { "enabled": true, "initialDelayMs": 500, "maxDelayMs": 30000, "maxAttempts": 8 } },
    "youtube": { "enabled": false, "inputEnabled": true, "outputEnabled": false, "adapter": "youtube-placeholder", "capabilities": ["chatInput", "chatOutput", "subscriptions", "donations", "moderation", "channelUpdates"], "reconnect": { "enabled": true, "initialDelayMs": 500, "maxDelayMs": 30000, "maxAttempts": 8 } },
    "kick": { "enabled": false, "inputEnabled": true, "outputEnabled": false, "adapter": "kick-placeholder", "capabilities": ["chatInput", "chatOutput", "follows", "subscriptions", "gifts", "raids", "moderation", "channelUpdates"], "reconnect": { "enabled": true, "initialDelayMs": 500, "maxDelayMs": 30000, "maxAttempts": 8 } },
    "tiktok": { "enabled": false, "inputEnabled": true, "outputEnabled": false, "adapter": "tikfinity-streamerbot", "capabilities": ["chatInput", "follows", "gifts", "engagement"], "reconnect": { "enabled": true, "initialDelayMs": 500, "maxDelayMs": 30000, "maxAttempts": 8 } },
    "facebook": { "enabled": false, "inputEnabled": true, "outputEnabled": false, "adapter": "facebook-placeholder", "capabilities": ["chatInput", "chatOutput", "follows", "subscriptions", "donations", "moderation", "channelUpdates"], "reconnect": { "enabled": true, "initialDelayMs": 500, "maxDelayMs": 30000, "maxAttempts": 8 } },
    "mock": { "enabled": true, "inputEnabled": true, "outputEnabled": false, "adapter": "mock", "capabilities": ["chatInput", "follows", "subscriptions", "gifts", "donations", "raids", "moderation", "engagement", "channelUpdates", "timedActions"], "reconnect": { "enabled": false, "initialDelayMs": 10, "maxDelayMs": 10, "maxAttempts": 0 } },
    "timers": { "enabled": true, "inputEnabled": true, "outputEnabled": false, "adapter": "timed-actions", "capabilities": ["timedActions"], "reconnect": { "enabled": false, "initialDelayMs": 10, "maxDelayMs": 10, "maxAttempts": 0 } }
  },
  "outputs": {
    "streamerbot": { "enabled": true, "adapter": "streamerbot", "settings": {} }
  }
}
