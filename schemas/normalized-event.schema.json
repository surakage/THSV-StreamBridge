{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:thsv:streambridge:schema:normalized-event:1.0.0",
  "title": "THSV StreamBridge Normalized Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "eventId", "eventType", "platform", "source", "receivedAt", "channel", "payload", "metadata"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "eventId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "eventType": { "type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$", "not": { "enum": ["viewer.progression", "companion.action"] }, "description": "A standard or extension event type. Archived add-on event types are excluded from core." },
    "platform": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$", "description": "An open lowercase platform identifier; third-party platform names do not require a shared-schema change." },
    "source": { "type": "object", "additionalProperties": false, "required": ["adapter", "eventName"], "properties": { "adapter": { "type": "string" }, "eventId": { "type": "string" }, "eventName": { "type": "string" } } },
    "receivedAt": { "type": "string", "format": "date-time" },
    "channel": { "type": "object", "additionalProperties": false, "required": ["name"], "properties": { "id": { "type": "string" }, "name": { "type": "string" } } },
    "user": { "type": "object", "additionalProperties": false, "required": ["name", "roles"], "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "displayName": { "type": "string" }, "actorType": { "type": "string", "enum": ["human", "bot", "system"], "default": "human" }, "roles": { "type": "array", "items": { "type": "string" } } } },
    "payload": { "type": "object" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["simulated"], "properties": { "correlationId": { "type": "string" }, "bridgeSequence": { "type": "integer", "minimum": 1, "description": "Process-local arrival sequence assigned by the bridge after deduplication; caller-supplied values are overwritten." }, "simulated": { "type": "boolean" }, "unverifiedFields": { "type": "array", "items": { "type": "string" } }, "rawPayload": {} } }
  }
}
